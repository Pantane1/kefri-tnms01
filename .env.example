# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Frontend URL (for redirects + CORS)
CLIENT_URL=http://localhost:3000

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-strong-random-secret-for-verification-tokens
SESSION_SECRET=replace-with-strong-random-secret-for-session-tokens

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Get from https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Dev: use Ethereal → https://ethereal.email (free fake SMTP, shows sent emails in browser)
# Prod: Resend (resend.com) or SendGrid or SMTP of your provider
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-ethereal-username
EMAIL_PASS=your-ethereal-password
EMAIL_FROM="Your App" <noreply@yourapp.com>
